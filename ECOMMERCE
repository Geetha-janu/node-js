<!DOCTYPE html>
<html>
<head>

<title>BVRIT CEMENT FACTORY</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
margin:0;
font-family:Arial;
}

header{
background:#196ddc;
color:white;
text-align:center;
padding:15px;
position:relative;
}

.logo{
width:60px;
position:absolute;
left:10px;
top:10px;
}

.sidebar{
background:#ffffff;
height:100vh;
padding-top:20px;
}

.sidebar a{
display:block;
color:rgb(235, 149, 149);
padding:12px;
text-decoration:none;
}

.sidebar a:hover{
background:#8ccbf0;
}

.content{
padding:20px;
background:#eee;
min-height:100vh;
padding-bottom:60px;
overflow:auto;
}

footer{
background:#212121;
color:white;
text-align:center;
padding:10px;
position:fixed;
bottom:0;
width:100%;
}
</style>

<script>

let cart = [];
let registeredUser = null;

function showPage(page){

document.getElementById("registration").style.display="none";
document.getElementById("login").style.display="none";
document.getElementById("catalog").style.display="none";
document.getElementById("cart").style.display="none";
document.getElementById("logout").style.display="none";

document.getElementById(page).style.display="block";

if(page === "cart"){
displayCart();
}
}

function registerUser(){

let name = document.getElementById("regName").value;
let email = document.getElementById("regEmail").value;
let pass = document.getElementById("regPass").value;
let confirm = document.getElementById("regConfirm").value;

if(name === "" || email === "" || pass === "" || confirm === ""){
alert("Please fill all fields");
return;
}

if(pass !== confirm){
alert("Passwords do not match");
return;
}

registeredUser = {
email: email,
password: pass
};

alert("Registration Successful!");
showPage('login');
}

function loginUser(){

let email = document.getElementById("loginEmail").value;
let pass = document.getElementById("loginPass").value;

if(!registeredUser){
alert("Please register first");
return;
}

if(email === registeredUser.email && pass === registeredUser.password){
alert("Login Successful!");
showPage('catalog');
}else{
alert("Invalid credentials");
}
}

function addToCart(product, price){
cart.push({name: product, price: price});
alert(product + " added to cart");
}

function displayCart(){
let cartDiv = document.getElementById("cart");

if(cart.length === 0){
cartDiv.innerHTML = "<h3>Your Cart is Empty</h3>";
return;
}

let html = "<h3>Your Cart</h3><ul class='list-group'>";
let total = 0;

cart.forEach(item => {
html += `<li class="list-group-item">${item.name} - ₹${item.price}</li>`;
total += item.price;
});

html += `</ul><h4 class="mt-3">Total: ₹${total}</h4>`;
cartDiv.innerHTML = html;
}

</script>

</head>

<body>

<header>
<img src="https://pbs.twimg.com/profile_images/1538007828618588165/ZBzOreDZ_400x400.jpg" class="logo">
<h3>BVRIT E-COMMERCE WEBSITE</h3>
</header>

<div class="container-fluid">
<div class="row">

<div class="col-md-2 sidebar">
<a href="#" onclick="showPage('registration')">REGISTRATION</a>
<a href="#" onclick="showPage('login')">LOGIN</a>
<a href="#" onclick="showPage('catalog')">CATALOG</a>
<a href="#" onclick="showPage('cart')">CART</a>
<a href="#" onclick="showPage('logout')">LOGOUT</a>
</div>

<div class="col-md-10 content">

<!-- REGISTRATION -->
<div id="registration">
<h3>Create Account</h3>

<input id="regName" class="form-control mb-2" placeholder="Full Name">
<input id="regEmail" class="form-control mb-2" placeholder="Email">
<input id="regPass" type="password" class="form-control mb-2" placeholder="Password">
<input id="regConfirm" type="password" class="form-control mb-2" placeholder="Confirm Password">

<button class="btn btn-primary" onclick="registerUser()">Submit</button>
</div>

<!-- LOGIN -->
<div id="login" style="display:none">
<h3>Login Page</h3>

<input id="loginEmail" class="form-control mb-2" placeholder="Email">
<input id="loginPass" type="password" class="form-control mb-2" placeholder="Password">

<button class="btn btn-success" onclick="loginUser()">Login</button>
</div>

<!-- CATALOG -->
<div id="catalog" style="display:none">
<h3>Product Catalog</h3>

<div class="card p-3 mb-2">
Laptop - ₹50000
<button class="btn btn-sm btn-primary float-end"
onclick="addToCart('Laptop',50000)">Add to Cart</button>
</div>

<div class="card p-3 mb-2">
Mobile - ₹20000
<button class="btn btn-sm btn-primary float-end"
onclick="addToCart('Mobile',20000)">Add to Cart</button>
</div>

<div class="card p-3 mb-2">
Headphones - ₹3000
<button class="btn btn-sm btn-primary float-end"
onclick="addToCart('Headphones',3000)">Add to Cart</button>
</div>

</div>

<!-- CART -->
<div id="cart" style="display:none">
<h3>Your Cart is Empty</h3>
</div>

<!-- LOGOUT -->
<div id="logout" style="display:none">
<h3>You have Logged Out</h3>
</div>

</div>
</div>
</div>

<footer>
© 2024 BVRITH. All rights reserved.
</footer>

</body>
</html>
